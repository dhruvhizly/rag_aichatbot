# App
APP_NAME=AI_Chatbot
DEBUG=false
UPLOAD_DIR=uploads

# Ollama / LLM
OLLAMA_BASE_URL=
OLLAMA_MODEL=
LLM_NUM_CTX=2048
LLM_NUM_PREDICT=512
LLM_KEEP_ALIVE=30m

# Conversation
HISTORY_MAX_TURNS=3

# Chunking
CHUNK_SIZE=400
CHUNK_OVERLAP=0

# Vector store
CHROMA_DB_DIR=chroma_db

# Embeddings
EMBEDDING_MODEL=
EMBEDDING_CACHE_DIR=models

# Retrieval + reranking
RAG_TOP_K=1
RAG_RERANK_POOL=5
RAG_MIN_RELEVANCE_SCORE=0.06
RERANKER_MODEL=

# Legacy / unused (kept for backwards compatibility, ignored by Settings)
AGENT_TEMPERATURE=0.5 
